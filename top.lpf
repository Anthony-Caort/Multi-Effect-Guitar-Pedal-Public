IOBUF PORT "rx_data" DRIVE=4 IO_TYPE=LVCMOS33;

// depth switches located on P4 
LOCATE COMP "depth_switches[0]" SITE "E3";
INPUT PORT "depth_switches[0]" IO_TYPE=LVCM0S33;
LOCATE COMP "depth_switches[1]" SITE "C3";
INPUT PORT "depth_switches[1]" IO_TYPE=LVCM0S33;
LOCATE COMP "depth_switches[2]" SITE "C4";
INPUT PORT "depth_switches[2]" IO_TYPE=LVCM0S33;
LOCATE COMP "depth_switches[3]" SITE "R8";
INPUT PORT "depth_switches[3]" IO_TYPE=LVCM0S33;

//button switches located on P4
LOCATE COMP "distortion_button" SITE "J2";
INPUT PORT "distortion_button" IO_TYPE=LVCM0S33;
LOCATE COMP "tremolo_button" SITE "J3";
INPUT PORT "tremolo_button" IO_TYPE=LVCM0S33;