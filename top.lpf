LOCATE COMP "tx_mclk" SITE "A5";
IOBUF PORT "tx_mclk" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "tx_lrck" SITE "A6";
IOBUF PORT "tx_lrck" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "tx_sclk" SITE "A7";
IOBUF PORT "tx_sclk" DRIVE=4 IO_TYPE=LVCMOS33;
LOCATE COMP "tx_data" SITE "A8";
IOBUF PORT "tx_data" DRIVE=4 IO_TYPE=LVCMOS33;

LOCATE COMP "rx_mclk" SITE "B5";
